#!/bin/bash
# opskit commit-msg hook — validate ticket reference from env.yml
# Reads environments/$ACTIVE_ENV/env.yml for the expected ticket prefix.
set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Client-token guard — commit messages are published; they must never contain
# client-identifying tokens (see docs/client-data-policy.md).
if [ "${ALLOW_CLIENT_TOKENS:-0}" != "1" ]; then
    CLIENT_TOKENS=""
    if [ -d environments ]; then
        CLIENT_TOKENS=$(find environments -mindepth 1 -maxdepth 1 -type d ! -name example ! -name '.*' -printf '%f\n')
    fi
    if [ -f .client-tokens ]; then
        CLIENT_TOKENS="$CLIENT_TOKENS
$(grep -vE '^\s*(#|$)' .client-tokens)"
    fi
    for tok in $CLIENT_TOKENS; do
        if echo "$COMMIT_MSG" | grep -qiE "\b${tok}\b"; then
            echo "ERROR: Commit message contains the client token '${tok}'."
            echo "Commit messages are published — reference tickets as TKT-<num> and keep client context in the helpdesk."
            exit 1
        fi
    done
fi

# Detect ACTIVE_ENV from .env (site repo context)
ACTIVE_ENV=""
if [ -f ".env" ]; then
    ACTIVE_ENV=$(grep "^ACTIVE_ENV=" .env 2>/dev/null | cut -d= -f2 | tr -d '"')
fi

# Only enforce if we can resolve an environment and it has a ticket prefix
if [ -z "$ACTIVE_ENV" ]; then
    exit 0
fi

ENV_YML="environments/$ACTIVE_ENV/env.yml"
if [ ! -f "$ENV_YML" ]; then
    exit 0
fi

PREFIX=$(python3 -c "
import yaml
d = yaml.safe_load(open('$ENV_YML'))
print(d.get('ticket', {}).get('prefix', ''))
" 2>/dev/null)

if [ -z "$PREFIX" ]; then
    exit 0
fi

# Ticket enforcement applies to client-operation sessions, which always have
# an open ticket (bin/open-ticket.sh writes .current-ticket). Tool development
# with no open ticket is exempt — the client-token guard above still applies.
if [ ! -s .current-ticket ]; then
    exit 0
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# Check if any staged file is infrastructure work (ansible/, inventory/, environments/ excluding example/)
HAS_INFRA=0
for f in $STAGED; do
    case "$f" in
        ansible/*|inventory/*|environments/*/datasets/*|environments/*/ansible/*)
            case "$f" in
                environments/example/*) ;;
                *) HAS_INFRA=1; break ;;
            esac
            ;;
    esac
done

if [ $HAS_INFRA -eq 0 ]; then
    exit 0
fi

# Published commit messages use the neutral TKT-<num> form; the full
# client-identifying <PREFIX>-<num> ID lives only in .current-ticket and the
# helpdesk (docs/client-data-policy.md).
if ! echo "$COMMIT_MSG" | grep -qiE "^TKT-[0-9]+:"; then
    echo "ERROR: Infrastructure changes require a TKT-XXXX ticket reference."
    echo "  Add 'TKT-XXXX: ...' (number only — never the client's helpdesk prefix)."
    echo "  The active ticket's full ID is in .current-ticket."
    exit 1
fi

exit 0

# {{ ansible_managed }}
# ERP stack "{{ erp_stack_name }}" — {{ erp_stack_image }}
# Generated by the opskit erp-stack role; edit group_vars, not this file.
#
# Site data lives in host bind mounts under {{ erp_stack_data_root }} (never
# opaque named volumes) so it is directly visible and backup-able on the host
# and survives container replacement.
#
# NOTE: "$$" is Compose's escape for a literal "$" — those values are resolved
# by the shell/nginx inside the container, not by Compose.

name: {{ erp_stack_name }}

x-erp-service: &erp_service
  image: {{ erp_stack_image }}
  platform: linux/amd64
  volumes:
    - {{ erp_stack_data_root }}/sites:/home/frappe/frappe-bench/sites
  restart: unless-stopped

x-after-configurator: &after_configurator
  depends_on:
    configurator:
      condition: service_completed_successfully

services:
  configurator:
    <<: *erp_service
    entrypoint: ["bash", "-c"]
    command:
      # A fresh bind-mounted sites/ dir is empty (unlike a named volume, which
      # copies the image's sites/ content on first use) — seed
      # common_site_config.json or every bench set-config below fails.
      - |
        ls -1 apps > sites/apps.txt; [ -f sites/common_site_config.json ] || echo "{}" > sites/common_site_config.json; bench set-config -g db_host $$DB_HOST; bench set-config -gp db_port $$DB_PORT; bench set-config -g redis_cache "redis://$$REDIS_CACHE"; bench set-config -g redis_queue "redis://$$REDIS_QUEUE"; bench set-config -g redis_socketio "redis://$$REDIS_QUEUE"; bench set-config -gp socketio_port $$SOCKETIO_PORT; bench set-config -g chromium_path /usr/bin/chromium-headless-shell;
    environment:
      DB_HOST: db
      DB_PORT: "3306"
      REDIS_CACHE: redis-cache:6379
      REDIS_QUEUE: redis-queue:6379
      SOCKETIO_PORT: "9000"
    depends_on:
      db: { condition: service_healthy }
      redis-cache: { condition: service_started }
      redis-queue: { condition: service_started }
    restart: on-failure

  backend:
    <<: [*erp_service, *after_configurator]
    environment:
      GUNICORN_WORKERS: "{{ erp_stack_gunicorn_workers }}"
      GUNICORN_THREADS: "{{ erp_stack_gunicorn_threads }}"
      GUNICORN_TIMEOUT: "{{ erp_stack_gunicorn_timeout }}"

  frontend:
    <<: *erp_service
    command: ["nginx-entrypoint.sh"]
    environment:
      BACKEND: backend:8000
      SOCKETIO: websocket:9000
      FRAPPE_SITE_NAME_HEADER: {{ erp_stack_site_name_header }}
      CLIENT_MAX_BODY_SIZE: {{ erp_stack_client_max_body_size }}
      PROXY_READ_TIMEOUT: "{{ erp_stack_gunicorn_timeout }}"
      UPSTREAM_REAL_IP_ADDRESS: 127.0.0.1
      UPSTREAM_REAL_IP_HEADER: X-Forwarded-For
      UPSTREAM_REAL_IP_RECURSIVE: "off"
    ports:
      - "{{ erp_stack_http_port }}:8080"
    depends_on:
      backend: { condition: service_started }
      websocket: { condition: service_started }

  websocket:
    <<: [*erp_service, *after_configurator]
    command: ["node", "/home/frappe/frappe-bench/apps/frappe/socketio.js"]

  queue-short:
    <<: [*erp_service, *after_configurator]
    command: ["bench", "worker", "--queue", "short,default"]

  queue-long:
    <<: [*erp_service, *after_configurator]
    command: ["bench", "worker", "--queue", "long,default,short"]

  scheduler:
    <<: [*erp_service, *after_configurator]
    command: ["bench", "schedule"]

  db:
    image: {{ erp_stack_mariadb_image }}
    command:
      - --character-set-server=utf8mb4
      - --collation-server=utf8mb4_unicode_ci
      - --skip-character-set-client-handshake
    environment:
      MARIADB_AUTO_UPGRADE: "1"
      MYSQL_ROOT_PASSWORD: "{{ erp_stack_db_root_password }}"
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      timeout: 5s
      interval: 5s
      retries: 5
      start_period: 5s
    volumes:
      - {{ erp_stack_data_root }}/db-data:/var/lib/mysql
    restart: unless-stopped

  redis-cache:
    image: {{ erp_stack_redis_image }}
    restart: unless-stopped

  redis-queue:
    image: {{ erp_stack_redis_image }}
    volumes:
      - {{ erp_stack_data_root }}/redis-queue-data:/data
    restart: unless-stopped

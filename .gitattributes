# opskit .gitattributes
# Ensure consistent line endings and treat binary files correctly

* text=auto

# Shell scripts must use LF
*.sh text eol=lf

# Python
*.py text eol=lf diff=python

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf diff=markdown

# Binary files
*.backup binary
*.tar.gz binary
*.zip binary
*.png binary
*.jpg binary
